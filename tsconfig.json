{
  // Extend the tsconfig Nuxt generates (`nuxi prepare` / `bun dev` / postinstall
  // keep it fresh) so the editor and CLI see the exact same aliases (#app,
  // #imports, @ → src, …) and types. If your editor shows "Cannot find name
  // 'useHead'"-style errors, .nuxt/ is stale or the TS server started before it
  // existed: run `bun install` (postinstall runs `nuxi prepare`), then
  // "Vue: Restart TS Server" / reload the window.
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    // The legacy src/ tree predates strict mode; flipping strict on is tracked
    // separately from the Nuxt migration.
    "strict": false,
    "noImplicitAny": false,
    "sourceMap": true
  },
  // The generated include covers app/** but not the legacy src/ tree (Nuxt only
  // reaches it via imports). List it here so src files opened directly in the
  // editor get full project context (aliases, globals, pug plugin).
  "include": [
    "./.nuxt/nuxt.d.ts",
    "app/**/*",
    "src/**/*",
    "tests/**/*",
    "nuxt.config.ts"
  ],
  "exclude": ["node_modules", "dist", "public", ".output"],
  "vueCompilerOptions": {
    // Keep vue-router's plugin from the generated config, plus pug support for
    // the <template lang="pug"> views.
    "plugins": ["@vue/language-plugin-pug", "vue-router/volar/sfc-route-blocks"]
  }
}
