.tactic-toast(:class="actor === 'player' ? 'is-player' : 'is-opponent'")
  .tt-header
    span.tt-actor-label {{ actor === 'player' ? 'You played ' : 'Opposing counsel played ' }}
    strong.tt-name {{ tacticName }}
  .tt-divider
  .tt-results(v-if="results && results.some(r => r.change !== 0)")
    .tt-result(
      v-for="r in results.filter(r => r.change !== 0)"
      :key="r.justiceName"
      :class="r.change > 0 ? 'positive' : 'negative'"
    )
      span.tt-justice {{ r.justiceName }}
      span.tt-change {{ r.change > 0 ? '+' : '' }}{{ r.change }}
      span.tt-side-effect(v-if="r.isKnockon") (side effect)
  p.tt-no-effect(v-else) No measurable effect
