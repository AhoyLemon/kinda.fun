.court-game(:class="`phase-${ui.phase}`")
  header.court-header
    h1 ⚖️ {{ ui.title }}

  //- ── COURT SELECTOR ─────────────────────────────────────────
  main.court-select(v-if="ui.phase === 'courtSelect'")
    h2.section-label Select Your Court
    .court-mode-grid
      .court-mode-card(@click="selectCourtMode('current')")
        .cmc-icon 🏛
        .cmc-title Current Court
        .cmc-desc The 9 justices currently on the Supreme Court. John Roberts presides as Chief Justice.
        .cmc-badge Default
      .court-mode-card(@click="selectCourtMode('historical')")
        .cmc-icon 📜
        .cmc-title Historical Court
        .cmc-desc 9 justices drawn from current and historical pools. A random justice is appointed Chief.
      .court-mode-card(@click="selectCourtMode('fantasy')")
        .cmc-icon 🎭
        .cmc-title Fantasy Court
        .cmc-desc A court of celebrities and fictional characters. Anything can happen. A random justice leads.
      .court-mode-card(@click="selectCourtMode('chaos')")
        .cmc-icon 🌪
        .cmc-title Chaos Court
        .cmc-desc 9 justices from any pool — real, historical, celebrity, or fictional. Pure mayhem.

  //- ── LOADING ────────────────────────────────────────────────
  .court-loading(v-else-if="!game.currentCase")
    p Convening the court…

  //- ── SETUP PHASE ────────────────────────────────────────────
  main.court-main(v-else-if="ui.phase === 'setup'")

    section.case-section
      .case-section-header
        h2.section-label Today's Case
        .case-section-actions
          button.btn.btn--redeal(@click="dealGame") 🎲 New Draw
          button.btn.btn--switch(@click="resetToCourtSelect") ← Change Mode

      .case-card(:class="`case-type-${game.currentCase.caseType}`")
        .case-card__header
          span.case-type-badge {{ game.currentCase.caseType === 'historical' ? '📜 Historical' : '🎭 Fictional' }}
          span.case-year(v-if="game.currentCase.year") {{ game.currentCase.year }}
        h3.case-name {{ game.currentCase.name }}
        p.case-question "{{ game.currentCase.primaryQuestion }}"

        .case-sides
          .case-side.case-side--prosecution(:class="{ 'is-chosen': game.playerSide === 'prosecution' }")
            h4.side-role ⚔️ Prosecution
            p.side-name {{ game.currentCase.prosecution.name }}
            p.side-argument {{ game.currentCase.prosecution.argument }}
            span.side-party(:class="`party-${game.currentCase.prosecution.favoredBy.toLowerCase().replace(' ', '-')}`")
              | Favors {{ game.currentCase.prosecution.favoredBy }}s

          .case-side.case-side--defense(:class="{ 'is-chosen': game.playerSide === 'defendant' }")
            h4.side-role 🛡️ Defense
            p.side-name {{ game.currentCase.defendant.name }}
            p.side-argument {{ game.currentCase.defendant.argument }}
            span.side-party(:class="`party-${game.currentCase.defendant.favoredBy.toLowerCase().replace(' ', '-')}`")
              | Favors {{ game.currentCase.defendant.favoredBy }}s

        .case-actions(v-if="!game.playerSide")
          p.choose-prompt Choose your side:
          .side-buttons
            button.btn.btn--prosecution(@click="chooseSide('prosecution')") ⚔️ Argue for Prosecution
            button.btn.btn--defense(@click="chooseSide('defendant')") 🛡️ Argue for Defense

        .case-actions(v-else)
          p.chosen-label
            | You are arguing for:
            strong  {{ game.playerSide === 'prosecution' ? game.currentCase.prosecution.name : game.currentCase.defendant.name }}
          .side-buttons
            button.btn.btn--start(@click="startArguments") Begin Arguments →
            button.btn.btn--switch(@click="game.playerSide = null") Switch Sides

    section.bench-section
      .bench-header
        h2.section-label {{ benchLabel }}

      .bench-grid.overview
        .justice-card(
          v-for="justice in sortedBench"
          :key="justice.id"
          :class="[ \
            `type-${justice.justiceType}`, \
            { 'has-image': justiceImageUrl(justice), 'is-chief': justice.id === game.chiefJusticeId } \
          ]"
          @click="handleJusticeClick(justice)"
        )
          .justice-chief-badge(v-if="justice.id === game.chiefJusticeId") ⚖ Chief
          .justice-card__thumb(v-if="justiceImageUrl(justice)")
            img.justice-card__img(:src="justiceImageUrl(justice)" :alt="justice.name")
          .justice-bio
            .justice-card__badge {{ justiceTypeLabel(justice.justiceType) }}
            .justice-card__name {{ justice.name }}
            .justice-card__president(v-if="justice.nominatedBy") Appt. by {{ justice.nominatedBy.name }}
          .justice-card__hints
            span.hint-tag(v-for="hint in justiceHints(justice, 2)" :key="hint") {{ hint }}
          .justice-card__view-cta 🔍 View Profile

  //- ── PLAYING PHASE ──────────────────────────────────────────
  main.court-playing(v-else-if="ui.phase === 'playing'")

    //- Top bar: case + round + turn + actions
    .playing-topbar
      .topbar-left
        .topbar-case
          span.topbar-case-name {{ game.currentCase.name }}
          span.topbar-sep |
          span.topbar-side(:class="`side-${game.playerSide}`")
            | {{ game.playerSide === 'prosecution' ? '⚔️ Prosecution' : '🛡️ Defense' }}
        .topbar-turn
          span.topbar-round Round {{ game.round }}/{{ game.totalRounds }}
          span.topbar-actor.is-opponent(v-if="ui.opponentThinking") ⚖️ Opposing counsel is arguing…
          span.topbar-actor.is-player(v-else) ↙ Your turn
      .topbar-right
        .topbar-tally(v-tippy="tallyTooltip" :class="tallyClass")
          | {{ tallyDisplay }}
        button.btn.btn--report(@click="ui.courtReportVisible = true") 📋 Report

    //- Bench overview panel
    .bench-overview-bar(v-if="benchOverview")
      .overview-chip
        span.oc-label 👥 Gender
        span.oc-value {{ benchOverview.maleCount }}M / {{ benchOverview.femaleCount }}F
      .overview-chip
        span.oc-label 🏛 Politics
        span.oc-value
          span.party-chip(
            v-for="(count, party) in benchOverview.partyCounts"
            :key="party"
            :class="`party-${String(party).toLowerCase().replace(' ', '-')}`"
          ) {{ party }} ({{ count }})
      .overview-chip
        span.oc-label ⬆ Best Stat
        span.oc-value.stat--best {{ benchOverview.bestStat }}
      .overview-chip
        span.oc-label ⬇ Worst Stat
        span.oc-value.stat--worst {{ benchOverview.worstStat }}
      .overview-chip
        span.oc-label 🎯 Exploit
        span.oc-value.wk--flag {{ benchOverview.greatestWeakness }}

      .bench-grid.bench-grid--playing(
      :class="{ 'targeting-mode': game.selectedTacticId !== null }"
    )
        .justice-card.on-bench(
          v-for="justice in game.bench"
          :key="justice.id"
          :class="[ \
            `type-${justice.justiceType}`, \
            { \
              'has-image': justiceImageUrl(justice), \
              'is-ally': (game.leanings[justice.id] ?? 0) > 0, \
              'is-enemy': (game.leanings[justice.id] ?? 0) < 0, \
              'is-targetable': game.selectedTacticId !== null, \
              'is-shielded': game.playerShields.includes(justice.id), \
              'is-chief': justice.id === game.chiefJusticeId, \
            } \
          ]"
          @click="handleJusticeClick(justice)"
        )

          .justice-chief-badge(v-if="justice.id === game.chiefJusticeId") ⚖ Chief
          .justice-shield-badge(v-else-if="game.playerShields.includes(justice.id)") 🛡️
          .justice-shield-badge.opp-shield(v-else-if="game.opponentShields.includes(justice.id)") 🔒
          .justice-recused-badge(v-if="game.recusedJustices.includes(justice.id)") 🔕
          //.justice-card__badge {{ justiceTypeLabel(justice.justiceType) }}

          .pic-and-name(v-if="justiceImageUrl(justice)")
            .justice-card__thumb
              img.justice-card__img(:src="justiceImageUrl(justice)" :alt="justice.name")
            .justice-card__name {{ justice.name }}
          .justice-card__name(v-else) {{ justice.name }}


          .justice-vote
            .vote-label(
              :class="{ positive: (game.leanings[justice.id] ?? 0) > 0, negative: (game.leanings[justice.id] ?? 0) < 0 }"
            ) {{ voteLabel(game.leanings[justice.id] ?? 0) }}
            .vote-track
              .vote-midline
              .vote-fill(:style="voteMeterStyle(justice)")
          

    //- The Docket: shared card pool
    .court-docket(
      :class="{ 'is-claiming': game.claimingMode, 'is-opponent-turn': ui.opponentThinking }"
    )
      .docket-header
        .docket-title-row
          h3.docket-title
            | The Docket
            span.docket-subtitle  · shared pool
          .docket-meta
            span.deck-count 🃏 {{ game.deck.length }} in deck
            span.claimed-count(v-if="game.claimedCards.length")  · {{ game.claimedCards.length }} claimed by you
        p.claiming-hint(v-if="game.claimingMode")
          | Select {{ 2 - game.claimedSelections.length }} more card(s) to claim for your exclusive use.
        p.hand-hint(v-else-if="game.selectedTacticId !== null") ↑ Click a justice above to target them

      //- Claimed cards (player-exclusive)
      .docket-claimed(v-if="game.claimedCards.length")
        h4.docket-section-label 🔒 Your Dibs — only you can play these
        .tactic-card-row
          .tactic-card(
            v-for="tactic in game.claimedCards"
            :key="tactic.id"
            :class="[ \
              `card-type-${tactic.cardType}`, \
              { 'is-selected': game.selectedTacticId === tactic.id, 'is-claimed': true } \
            ]"
            @click="selectTactic(tactic.id)"
          )
            .tc__type {{ tactic.cardType }} · claimed
            .tc__name {{ tactic.name }}
            .tc__flavor {{ tactic.flavorText }}
            .tc__meta
              span.tc__target {{ targetLabel(tactic.effectType) }}
              span.tc__power(v-if="tactic.basePower > 0")  ⚡{{ tactic.basePower }}


      //- Shared docket cards
      .docket-shared
        p.docket-empty(v-if="!game.docket.length") The docket is empty.
        transition-group.tactic-card-row(v-else tag="div" name="tactic-card")
          .tactic-card(
            v-for="tactic in game.docket"
            :key="tactic.id"
            :class="[ \
              `card-type-${tactic.cardType}`, \
              { \
                'is-selected': game.selectedTacticId === tactic.id, \
                'is-claiming-pick': game.claimingMode && game.claimedSelections.includes(tactic.id), \
                'is-opponent-browsing': ui.opponentHighlightedCardId === tactic.id, \
              } \
            ]"
            @click="selectTactic(tactic.id)"
          )
            .tc__type {{ tactic.cardType }}
            .tc__name {{ tactic.name }}
            .tc__description {{ tactic.description }}
            .tc__flavor {{ tactic.flavorText }}
            .tc__meta
              span.tc__target {{ targetLabel(tactic.effectType) }}
              span.tc__power(v-if="tactic.basePower > 0")  ⚡{{ tactic.basePower }}
    //- ── OPPONENT THINKING OVERLAY ────────────────────────────────
    .opponent-thinking-overlay(v-if="ui.opponentThinking")
      .otl-message
        span.otl-icon ⚖️
        span.otl-text Opposing counsel is deliberating…
    //- ── TARGETING CHOICE POPUP ────────────────────────────
    .targeting-choice-overlay(v-if="ui.targetingChoice" @click.self="ui.targetingChoice = null")
      .targeting-choice
        p.tc-prompt Target {{ ui.targetingChoice.name }}?
        .tc-actions
          button.btn.btn--start(@click="confirmTarget()") ⚔️ Target This Justice
          button.btn.btn--switch(@click="ui.detailJustice = ui.targetingChoice; ui.targetingChoice = null") 🔍 View Profile
          button.btn.btn--text(@click="ui.targetingChoice = null") Cancel

  //- ── VERDICT PHASE ──────────────────────────────────────────
  main.court-verdict(v-else-if="ui.phase === 'verdict'")
    .verdict-card(:class="verdict && verdict.won ? 'verdict--won' : 'verdict--lost'")
      h2.verdict-title(v-if="verdict")
        | {{ verdict.won ? '🎉 Decision for Your Client!' : '⚖️ Judgment Against You' }}
      .verdict-score(v-if="verdict")
        span.score-for {{ verdict.forCount }}
        span.score-dash  –
        span.score-against {{ verdict.againstCount }}
        template(v-if="verdict.abstainCount > 0")
          span.score-dash  –
          span.score-abstain {{ verdict.abstainCount }}
      p.verdict-subtext(v-if="verdict")
        | {{ verdict.won ? 'The court finds in favor of your client.' : 'The court rules against your client.' }}
      .verdict-justices
        .verdict-justice(
          v-for="justice in game.bench"
          :key="justice.id"
          :class="(game.leanings[justice.id] ?? 0) > gameSettings.abstentionThreshold ? 'voted-for' : (game.leanings[justice.id] ?? 0) < -gameSettings.abstentionThreshold ? 'voted-against' : 'voted-abstain'"
        )
          span.vj-name {{ justice.name }}
          span.vj-vote {{ voteLabel(game.leanings[justice.id] ?? 0) }}
      .verdict-actions
        button.btn.btn--start(@click="resetToCourtSelect") ⚖️ New Court
        button.btn.btn--report(@click="ui.courtReportVisible = true") 📋 View Court Record

  include pug/modals/_court-record.pug
  include pug/modals/_justice-detail.pug