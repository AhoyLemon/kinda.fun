//- ── VERDICT PHASE ──────────────────────────────────────────
main.court-verdict(v-else-if="ui.phase === 'verdict'")
  .verdict-header(:class="verdict && (verdict.won ? 'verdict--won' : verdict.tied ? 'verdict--tied' : 'verdict--lost')")
    h2.verdict-title(v-if="verdict")
      | {{ verdict.won ? '🎉 Judgement In Your Favor!' : verdict.tied ? '⚖️ The Court Is Divided' : '⚖️ Judgement Against You' }}
    .verdict-score(v-if="verdict") {{ verdictScoreDisplay }}
    p.verdict-ruled-for(v-if="verdictRuledFor")
      | The court ruled for 
      strong  {{ verdictRuledFor }}
    p.verdict-winning-argument(v-if="verdictWinningArgument") "{{ verdictWinningArgument }}"

  

  .verdict-vote-sections(v-if="verdict")
    .verdict-vote-section(
      v-for="section in verdictSections"
      :key="section.type"
      :class="`verdict-section--${section.type}`"
    )
      h3.verdict-section-label {{ section.label }}
      .verdict-justices
        .verdict-justice(
          v-for="justice in section.justices"
          :key="justice.id"
          :class="{ 'vj--chief': justice.id === game.chiefJusticeId }"
        )
          .vj-chief-badge(v-if="justice.id === game.chiefJusticeId") ⚖ Chief Justice
          .vj-name {{ justice.name }}
          .vj-bar-track
            .vj-bar(:style="verdictJusticeBarStyle(justice)")
          .vj-chips(v-if="(justiceTargetings[justice.id] ?? []).length")
            span.vj-chip(
              v-for="(targeting, i) in justiceTargetings[justice.id]"
              :key="i"
              :class="`chip--${targeting.actor}`"
              v-tippy="`${targeting.actor === 'player' ? 'You' : 'Opponent'} played: ${targeting.tacticName}`"
            ) {{ targeting.actor === 'player' ? '⚔️' : '⚖️' }}

  .verdict-objective(v-if="ui.isCampaignMode && campaign.data?.activeObjective")
    .vo-objective
      span.vo-icon {{ campaign.data.activeObjective.icon }}
      span.vo-name {{ campaign.data.activeObjective.name }}
      span.vo-status(
        v-if="verdict && !verdict.tied"
        :class="objectiveStatus === 'passing' ? 'status--passing' : 'status--failing'"
      ) {{ objectiveStatus === 'passing' ? '✓ On track' : '✗ Off track' }}
      span.vo-status.status--tied(v-else-if="verdict && verdict.tied") ⚖ Tied — retrying
    span.vo-progress {{ campaignProgress }}

  .verdict-actions
    template(v-if="ui.isCampaignMode")
      button.btn.btn--start(v-if="verdict && verdict.won && objectiveStatus === 'failing'" @click="proceedAfterVerdict()") Continue →
      button.btn.btn--start(v-else-if="verdict && verdict.won" @click="proceedAfterVerdict()") 🏆 Receive Win Bonus →
      button.btn.btn--start(v-else-if="verdict && verdict.tied" @click="proceedAfterVerdict()") ↩ Retry Case
      button.btn.btn--start(v-else-if="verdict && !verdict.tied" @click="proceedAfterVerdict()") ⏸ Enter Recess →
      button.btn.btn--report(@click="ui.courtReportVisible = true") 📋 Court Record
    template(v-else)
      button.btn.btn--retry(v-if="verdict && !verdict.won && !verdict.tied" @click="retrySameCase()") 🔁 Retry Case
      button.btn.btn--start(@click="resetToCourtSelect") ⚖️ New Court
      button.btn.btn--report(@click="ui.courtReportVisible = true") 📋 View Court Record
