//- ── TITLE PHASE ────────────────────────────────────────────
main.court-title(v-if="ui.phase === 'title'")
  .video-holder.video-bg
    video(title="Supreme Court: The Card Game - Trailer" autoplay loop muted playsinline)
      source(src="/video/court/court-barricade.smaller.mp4" type="video/mp4")
      source(src="/video/court/court-barricade.webm" type="video/webm")
      source(src="/video/court/court-barricade.mov" type="video/quicktime")
  .title-hero
    figure
      img(src="/svg/games/supremecourt.svg" alt="Supreme Court: The Card Game" class="title-image")

  .title-mode-buttons
    .title-mode-section

      button.title-button.quickplay(@click="markPlayedQuickplay(); ui.phase = 'courtSelect'")
        .label Quick Play
        .desc Assemble a court and argue a single case
      p.title-hint(v-if="!hasPlayedQuickplay()") 
        span.hint-text
          span.emoji 👆
          span.text New here? Start with Quick Play!

    .title-mode-section
      button.title-button.campaign(@click="ui.phase = 'campaignSelect'")
        .label Start Campaign
        .desc Guide a court through a docket of historic cases