main.court-playing(v-if="ui.phase === 'playing'")

  //- Campaign progress banner
  .campaign-banner(v-if="ui.isCampaignMode && campaign.data")
    .cb-objective(v-if="campaign.data.activeObjective")
      span.cb-icon {{ campaign.data.activeObjective.icon }}
      span.cb-label {{ campaign.data.activeObjective.name }}
    span.cb-progress {{ campaignProgress }}
    span.cb-year 📅 {{ campaign.data.year }}

  //- Top bar: case + round + turn + actions
  .playing-topbar
    .topbar-left
      .topbar-case
        span.topbar-case-name {{ game.currentCase.name }}
        span.topbar-sep |
        span.topbar-side(:class="`side-${game.playerSide}`")
          | {{ game.playerSide === 'prosecution' ? '⚔️ Prosecution' : '🛡️ Defense' }}
      .topbar-turn
        span.topbar-round Round {{ game.round }}/{{ game.totalRounds }}
        span.topbar-actor.is-opponent(v-if="ui.opponentThinking") ⚖️ Opposing counsel is arguing…
        span.topbar-actor.is-player(v-else) ↙ Your turn
    .topbar-right
      .topbar-tally(v-tippy="tallyTooltip" :class="tallyClass")
        | {{ tallyDisplay }}
      button.btn.btn--report(@click="ui.courtReportVisible = true") 📋 Report
      template(v-if="cheatsActive")
        

  //- Bench overview panel
  .bench-overview-bar(v-if="benchOverview")
    .overview-chip
      span.oc-label 👥 Gender
      span.oc-value {{ benchOverview.maleCount }}M / {{ benchOverview.femaleCount }}F
    .overview-chip
      span.oc-label 🏛 Politics
      span.oc-value
        span.party-chip(
          v-for="(count, party) in benchOverview.partyCounts"
          :key="party"
          :class="`wing-${String(party).toLowerCase()}`"
        ) {{ party }} ({{ count }})
    .overview-chip
      span.oc-label ⬆ Best Stat
      span.oc-value.stat--best {{ benchOverview.bestStat }}
    .overview-chip
      span.oc-label ⬇ Worst Stat
      span.oc-value.stat--worst {{ benchOverview.worstStat }}
    .overview-chip
      span.oc-label 🎯 Exploit
      span.oc-value.wk--flag {{ benchOverview.greatestWeakness }}

    .targeting-banner(v-if="game.multiTargetMode")
      | 🎯 Select {{ 2 - game.multiTargetSelections.length }} justice{{ (2 - game.multiTargetSelections.length) === 1 ? '' : 's' }} — click the card again to cancel
    .targeting-banner.cheat-targeting(v-else-if="cheatsActive && ui.cheatTargetMode")
      | {{ ui.cheatTargetMode === 'love' ? '💕 Click a justice to set their leaning to +100' : '💀 Click a justice to set their leaning to −100' }} — click the button again to cancel
    .bench-grid.bench-grid--playing(
    :class="{ 'targeting-mode': game.selectedTacticId !== null || game.multiTargetMode }"
  )
      .justice-card.on-bench(
        v-for="justice in game.bench"
        :key="justice.id"
        :class="[ \
          `type-${justice.justiceType}`, \
          { \
            'has-image': justiceImageUrl(justice), \
            'is-ally': (game.leanings[justice.id] ?? 0) > 0, \
            'is-enemy': (game.leanings[justice.id] ?? 0) < 0, \
            'is-targetable': game.selectedTacticId !== null || game.multiTargetMode, \
            'is-shielded': game.playerShields.includes(justice.id), \
            'is-chief': justice.id === game.chiefJusticeId, \
            'is-napping': !!game.nappingJustices[justice.id], \
            'is-yoga': !!game.yogaJustices[justice.id], \
            'is-buffed': !!game.statMods[justice.id], \
            'is-sus': (game.susceptibilityMods[justice.id] ?? 0) > 0, \
            'is-multi-selected': game.multiTargetSelections.includes(justice.id), \
          } \
        ]"
        @click="handleJusticeClick(justice)"
      )

        .justice-chief-badge(v-if="justice.id === game.chiefJusticeId" v-tippy="'The Chief Justice is more difficult to sway, but can exert their own influence on other justices in the same party.'") ⚖ Chief

        .pic-and-name(v-if="justiceImageUrl(justice)")
          .justice-card__thumb
            img.justice-card__img(:src="justiceImageUrl(justice)" :alt="justice.name")
          .justice-card__name {{ justice.name }}
        .justice-card__name(v-else) {{ justice.name }}

        //- Overlay for napping / yoga (grayed out card + centered icon)
        .justice-napping-overlay(v-if="game.nappingJustices[justice.id]" v-tippy="'Napping — skipping this round. Wakes up warmer toward you.'") 💤
        .justice-napping-overlay(v-else-if="game.yogaJustices[justice.id]" v-tippy="'Finding inner peace — skipping this round. Returns with boosted empathy and susceptibility.'") 🧘

        .status-row(v-if="game.playerShields.includes(justice.id) || game.opponentShields.includes(justice.id) || game.recusedJustices.includes(justice.id) || game.statMods[justice.id] || (game.susceptibilityMods[justice.id] ?? 0) > 0 || game.draggedJustices.includes(justice.id) || game.religionOverrides[justice.id] === 'Catholic' || game.religionOverrides[justice.id] === 'Atheist'")
          span.status-icon(v-if="game.playerShields.includes(justice.id)" v-tippy="'Protected by you — blocks the next opposing argument.'") 🛡️
          span.status-icon(v-if="game.opponentShields.includes(justice.id)" v-tippy="'Protected by opponent — your next argument is blocked.'") 🔒
          span.status-icon(v-if="game.recusedJustices.includes(justice.id)" v-tippy="'Recused — harder to sway for the rest of the trial.'") 🔕
          span.status-icon(v-if="game.statMods[justice.id]" v-tippy="'Stats temporarily modified.'") 🍸
          span.status-icon(v-if="(game.susceptibilityMods[justice.id] ?? 0) > 0" v-tippy="'Lulled — the next argument will hit them significantly harder.'") 😵‍💫
          span.status-icon(v-if="game.draggedJustices.includes(justice.id)" v-tippy="'Dragged — charisma permanently lowered for this trial.'") ⬇️
          span.status-icon(v-if="game.religionOverrides[justice.id] === 'Catholic'" v-tippy="'Catholic for the rest of the trial.'") ☘️
          span.status-icon(v-if="game.religionOverrides[justice.id] === 'Atheist'" v-tippy="'Irreligious for the rest of the trial.'") 🍋


        .justice-vote
          .vote-label(
            :class="{ positive: (game.leanings[justice.id] ?? 0) > 0, negative: (game.leanings[justice.id] ?? 0) < 0 }"
          ) {{ voteLabel(game.leanings[justice.id] ?? 0) }}
          .vote-track
            .vote-midline
            .vote-fill(:style="voteMeterStyle(justice)")
        

  //- Trial reward cards (campaign mode)
  .court-trial-rewards(v-if="trialRewardCards.length")
    .trial-rewards-header
      span.trial-rewards-title 🃏 Your Trial Cards
    .trial-rewards-list
      .trial-reward-card(v-for="card in trialRewardCards" :key="card.id")
        span.trc-icon {{ card.icon }}
        span.trc-name {{ card.name }}
        button.btn.btn--small.btn--activate(
          v-if="card.id === 'double-tap'"
          :disabled="campaign.data?.doubleTapActive"
          @click="activateDoubleTap()"
        ) {{ campaign.data?.doubleTapActive ? '⚡ Active' : 'Activate' }}

  //- The Playbook: shared card pool
  .court-playbook(
    :class="{ 'is-claiming': game.claimingMode, 'is-opponent-turn': ui.opponentThinking, 'has-selection': game.selectedTacticId !== null || game.multiTargetMode }"
  )
    .playbook-header
      .playbook-title-row
        h3.playbook-title
          | The Playbook
          span.playbook-subtitle  · shared between both counsels
        .playbook-meta
          span.deck-count 🃏 {{ game.deck.length }} in deck
          span.claimed-count(v-if="game.claimedCards.length")  · {{ game.claimedCards.length }} claimed by you
      p.claiming-hint(v-if="game.claimingMode")
        | Select {{ 2 - game.claimedSelections.length }} more card(s) to claim for your exclusive use.
      p.hand-hint(v-else-if="game.multiTargetMode") 👆 Select {{ 2 - game.multiTargetSelections.length }} more justice{{ (2 - game.multiTargetSelections.length) === 1 ? '' : 's' }} above
      p.hand-hint(v-else-if="game.selectedTacticId !== null") ↑ Click a justice above to target them

    //- Claimed cards (player-exclusive)
    .playbook-claimed(v-if="game.claimedCards.length")
      h4.playbook-section-label 🔒 Your Dibs — only you can play these
      .tactic-card-row
        .tactic-card(
          v-for="tactic in game.claimedCards"
          :key="tactic.id"
          :class="[ \
            `card-type-${tactic.cardType}`, \
            { \
              'is-selected': game.selectedTacticId === tactic.id || game.multiTargetTacticId === tactic.id, \
              'is-claimed': true, \
              'is-disabled': tactic.effectType === 'betray-friend' && !hasStrongAlly, \
            } \
          ]"
          @click="selectTactic(tactic.id)"
        )
          .tc__type {{ tactic.cardType }} · claimed
          .tc__name {{ tactic.name }}
          .tc__flavor {{ tactic.flavorText }}
          .tc__meta
            span.tc__target {{ targetLabel(tactic.effectType) }}
            span.tc__power(v-if="tactic.basePower > 0")  ⚡{{ tactic.basePower }}


    //- Shared playbook cards
    .playbook-shared
      p.playbook-empty(v-if="!game.playbook.length") The playbook is empty.
      transition-group.tactic-card-row(v-else tag="div" name="tactic-card")
        .tactic-card(
          v-for="tactic in game.playbook"
          :key="tactic.id"
          :class="[ \
            `card-type-${tactic.cardType}`, \
            { \
              'is-selected': game.selectedTacticId === tactic.id || game.multiTargetTacticId === tactic.id, \
              'is-claiming-pick': game.claimingMode && game.claimedSelections.includes(tactic.id), \
              'is-opponent-browsing': ui.opponentHighlightedCardId === tactic.id, \
              'is-disabled': tactic.effectType === 'betray-friend' && !hasStrongAlly, \
            } \
          ]"
          @click="selectTactic(tactic.id)"
        )
          .tc__type {{ tactic.cardType }}
          .tc__name {{ tactic.name }}
          .tc__description {{ tactic.description }}
          .tc__flavor {{ tactic.flavorText }}
          .tc__meta
            span.tc__target {{ targetLabel(tactic.effectType) }}
            span.tc__power(v-if="tactic.basePower > 0")  ⚡{{ tactic.basePower }}
  //- ── OPPONENT THINKING OVERLAY ────────────────────────────────
  .opponent-thinking-overlay(v-if="ui.opponentThinking")
    .otl-message
      span.otl-icon ⚖️
      span.otl-text Opposing counsel is deliberating…
  //- ── TARGETING CHOICE POPUP ────────────────────────────
  .targeting-choice-overlay(v-if="ui.targetingChoice" @click.self="ui.targetingChoice = null")
    .targeting-choice
      p.tc-prompt Target {{ ui.targetingChoice.name }}?
      .tc-actions
        button.btn.btn--start(@click="confirmTarget()") ⚔️ Target This Justice
        button.btn.btn--switch(@click="ui.detailJustice = ui.targetingChoice; ui.targetingChoice = null") 🔍 View Profile
        button.btn.btn--text(@click="ui.targetingChoice = null") Cancel

  //- ── REFRAME THE DEBATE stance picker ────────────────────
  .reframe-stance-overlay(v-if="game.reframeStanceMode" @click.self="cancelReframeStance()")
    .reframe-stance-picker
      p.rs-title 🔄 What is this case about?
      p.rs-subtitle Choose a stance. Every justice with a known position on it will react immediately.
      .rs-choices
        button.btn.btn--stance(
          v-for="info in reframeStanceStats"
          :key="info.stance"
          @click="confirmReframeStance(info.stance)"
        )
          span.rs-stance-name {{ info.stance.replace(/([A-Z])/g, ' $1').trim() }}
          span.rs-stance-counts
            span.rs-for(v-if="info.forCount" v-tippy="`${info.forCount} justices are FOR this — they will warm to you`") ▲{{ info.forCount }}
            span.rs-against(v-if="info.againstCount" v-tippy="`${info.againstCount} justices are AGAINST this — they will lean away`") ▼{{ info.againstCount }}
      button.btn.btn--text(@click="cancelReframeStance()") Cancel