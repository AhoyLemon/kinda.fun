  .player-table 
    h2 Top Players
    .good-table.player-table(v-if="stats?.general?.players")
      vue-good-table(:rows="stats.general.players"
        theme="black-rhino"
        :columns="columns.generalPlayers"
        :sort-options="{ enabled: true, initialSortBy: {field: 'gamesPlayed', type: 'desc'} }"
        :pagination-options="{ enabled: true, perPage: 20, position: 'top', perPageDropdown: [10, 20, 50], dropdownAllowAll: true, nextLabel: 'next',prevLabel: 'prev',}")
    .table-under(v-if="stats?.general?.players_isLimited")
      button.load-full(@click="loadFullData('general', 'players')" :disabled="ui.loadingFullData")
        | {{ ui.loadingFullData ? 'Loading...' : `Show All (currently top ${stats.general.players_limitTo})` }}

  aside.last-cloned-holder(v-if="stats?.general?.lastCloned")
    .last-cloned
      span 🗄️ Database was last cloned  &nbsp; 
      strong(v-text="formatTime(stats.general.lastCloned, 'calendar')")