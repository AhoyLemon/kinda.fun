main.general-stats(v-if="ui.viewing == 'general'")

  .inside

    .game-summaries

      .summary
        figure
          button(@click="getData('cameo')") 
            img(src="/svg/games/comparativelyfamous.svg" alt="Comparatively Famous")
        .last-played(v-if="stats.general && stats.general.cameoLastPlayed")
          .time-ago(v-text="formatTime(stats.general.cameoLastPlayed,'fromNow')")
          .calendar(v-text="formatTime(stats.general.cameoLastPlayed,'calendar')")

      .summary
        figure
          button(@click="getData('court')") 
