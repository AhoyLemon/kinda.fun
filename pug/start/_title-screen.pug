  .create-or-join(v-if="gameChoice")
    .options(v-if="gameChoice == 'invalid' || gameChoice == 'wrongest'")
      .create
        button(@click="createRoom()") Create a New Room

      .or
        span or

      .join
        button(@click="joinRoom()") Join a Room
    .start-playing(v-else)
      button(@click="startSinglePlayerGame()") Start Playing
    