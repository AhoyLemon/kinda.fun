include _things.pug

.title-screen

  .choice-holder

    .inner
      .above-choices 
        h1 Choose a game.

      .game-choices

        .game(:class="{ active: (gameChoice == 'guillotine'), inactive: (gameChoice && gameChoice != 'guillotine') }")
          button.logo(@click="setActiveGame('guillotine')")
            img(src="svg/games/nomorebillionaires.svg" alt="No More Billionaires! logo")
          figcaption
            .slogan Generating Wealth with a Guillotine
            .players-allowed
              | For 1 player.
              br
              | (with a new set of choices every day)
          script(type="application/ld+json").
            {
              "@context": "http://schema.org",
              "@type": "VideoGame",
              "name": "NO MORE BILLIONAIRES",
              "url": "https://kinda.fun/guillotine",
              "image": "https://kinda.fun/img/og-guillotine.jpg",
              "playMode": "SinglePlayer",
              "applicationCategory": "browser game",
              "gamePlatform": "web browser",
              "operatingSystem": "web browser",
              "genre": "comedy",
              "description": "The game where you generate wealth through the use of a guillotine."
            }

        .game(:class="{ active: (gameChoice == 'cameo'), inactive: (gameChoice && gameChoice != 'cameo') }")
