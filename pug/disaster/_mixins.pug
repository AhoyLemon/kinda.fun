mixin timeStamp()
  - var d = new Date()
  - var m = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December' ]
  time 
    = m[d.getMonth()] 
    |  
    = d.getDate()
    | , 
    = d.getFullYear() 


mixin formatDate(d)
  - var allMonths = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December' ]
  - var MonthAbbr = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec' ]
  - var e = d.split("-");
  time(datetime=d)
    = MonthAbbr[parseInt(e[1] - 1)]
    |  
    = e[2]
    | , 
    = e[0]


mixin outsideLink(title,url)
  a.link(href=url target="_blank" noopener @click="trackLink('"+title+"', '"+url+"')")= title


mixin group(num,effect)
  - const imgPath = "img/bop/bg"

  if num == 3
    .group.group3
      .group-header More Important News
      transition-group(name=effect tag="div" class="box-container")
        .box(v-for="(box, index) in news.group"+num+".boxes" :key="index" :class="boxClasses(box)")
          figure.clickable(v-if="box.img" :style="'background-image:url("+imgPath+"/'+box.img+')'" @click="chooseArticle(box)")
          figcaption
            .headline(v-if="box.headline")
              a(@click="chooseArticle(box)" v-text="parseHeadline(box.headline)")
            time.datestamp(v-if="box.dateStamp" v-text="box.dateStamp")

  else
    transition-group(name=effect tag="div" class="group group"+num)
      .box(v-for="(box, index) in news.group"+num+".boxes" :key="index" :class="boxClasses(box)")
        if num == 1 || num == 6
          figure.bg(v-if="box.img" :style="'background-image:url("+imgPath+"/'+box.img+')'")
          figcaption
            .headline(v-if="box.headline")
              a(@click="chooseArticle(box)" v-text="parseHeadline(box.headline)")
            time.datestamp(v-if="box.dateStamp && box.type != 'ad'" v-text="box.dateStamp")
          .category(v-if="box.category" v-text="box.category")
          .sponsored(v-else-if="box.type == 'ad'") Sponsored
        if num == 2
          figure.clickable(v-if="box.img" :style="'background-image:url("+imgPath+"/'+box.img+')'" @click="chooseArticle(box)")
          .right
            .category(v-if="box.category" v-text="box.category")
            .sponsored(v-else-if="box.type == 'ad'") Sponsored
            .headline(v-if="box.headline")
              a(@click="chooseArticle(box)" v-text="parseHeadline(box.headline)") 
            time.datestamp(v-if="box.dateStamp" v-text="box.dateStamp")
        if num == 4
          figure.clickable(v-if="box.img" :style="'background-image:url("+imgPath+"/'+box.img+')'" @click="chooseArticle(box)")
          figcaption
            .category(v-if="box.category" v-text="box.category")
            .sponsored(v-else-if="box.type == 'ad'") Sponsored
            .headline(v-if="box.headline")
              a(@click="chooseArticle(box)" v-text="parseHeadline(box.headline)")
        if num == 5
          .headline(v-if="box.headline")
            a(@click="chooseArticle(box)" v-text="parseHeadline(box.headline)")
          div 
            time.datestamp(v-if="box.dateStamp" v-text="box.dateStamp")
            span.category(v-if="box.category" v-text="box.category")