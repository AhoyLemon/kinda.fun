{
  "name": "kinda-fun",
  "version": "2.0.2",
  "private": true,
  "type": "module",
  "description": "Games made by Lemon.",
  "scripts": {
    "dev": "node scripts/npm-run/dev.js",
    "dev:client": "vite --host",
    "build:pages": "node scripts/npm-run/buildPages.js",
    "build": "node scripts/npm-run/build.js",
    "preview": "vite preview --host",
    "test:watch": "vitest",
    "test:run": "vitest --run",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "guillotine:csv": "node scripts/npm-run/guillotine_mergeCsv.js",
    "guillotine:js": "node scripts/npm-run/guillotine_generateJs.js",
    "guillotine:arrests": "node scripts/npm-run/guillotine_createArrests.js",
    "watch:pages": "node scripts/npm-run/watchPages.js",
    "firebase:hydrate": "node scripts/firebase/cloneFirestore.js",
    "firebase:check": "node scripts/firebase/testFirebaseConnections.js",
    "postinstall": "cd functions && npm install",
    "purge:rooms": "node scripts/firebase/invalid_purgeRooms.js"
  },
  "dependencies": {
    "@vueform/multiselect": "^2.6.11",
    "firebase": "^12.11.0",
    "firebase-functions": "^7.2.2",
    "howler": "^2.2.4",
    "luxon": "^3.7.2",
    "vue": "^3.5.31",
    "vue-tippy": "^6.7.1",
    "vue-toastification": "^2.0.0-rc.5",
    "vuedraggable": "^4.1.0",
    "vuefire": "^3.2.2"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.16.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/language-plugin-pug": "^2.2.12",
    "@vue/test-utils": "^2.4.6",
    "cli-table3": "^0.6.5",
    "colors": "^1.4.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "firebase-admin": "^13.7.0",
    "jquery": "^3.7.1",
    "jsdom": "^24.1.3",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "pug": "^3.0.4",
    "sass": "^1.98.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-vue-devtools": "^7.7.9",
    "vitest": "^3.2.4",
    "vue-good-table-next": "^0.2.2"
  },
  "overrides": {
    "firebase": {
      "undici": "^6.21.3"
    }
  }
}
