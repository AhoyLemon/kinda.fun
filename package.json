{
  "name": "kinda-fun",
  "version": "2.0.2",
  "private": true,
  "type": "module",
  "description": "Games made by Lemon.",
  "scripts": {
    "dev": "nuxi dev",
    "generate": "nuxi generate",
    "build": "node scripts/updateSitemap.js && nuxi generate",
    "preview": "nuxi preview",
    "verify": "node scripts/verify/verify.mjs",
    "sass:check": "node scripts/checkSass.mjs",
    "typecheck": "nuxi typecheck",
    "deploy": "npm run build && firebase deploy --only hosting",
    "sitemap": "node scripts/updateSitemap.js",
    "test": "node scripts/npm-run/test.js",
    "test:watch": "vitest",
    "test:run": "vitest --run",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "guillotine:scrape": "bun run scripts/scrapers/forbesBillionaires.ts",
    "guillotine:school": "bun run scripts/scrapers/schoolData.ts",
    "guillotine:csv": "bun run scripts/npm-run/guillotine_updateCurrentList.ts",
    "guillotine:ts": "bun run scripts/npm-run/guillotine_generateTs.ts",
    "guillotine:arrests": "bun run scripts/npm-run/guillotine_createArrests.ts",
    "megachurch:sermons": "bun run scripts/megachurch_sermonReport.js",
    "firebase:hydrate": "node scripts/firebase/cloneFirestore.js",
    "firebase:check": "node scripts/firebase/testFirebaseConnections.js",
    "postinstall": "nuxi prepare && cd functions && npm install",
    "purge:rooms": "node scripts/firebase/invalid_purgeRooms.js"
  },
  "dependencies": {
    "@vueform/multiselect": "^2.6.11",
    "firebase": "^12.15.0",
    "howler": "^2.2.4",
    "luxon": "^3.7.2",
    "nuxt": "^4.4.8",
    "tippy.js": "^6.3.7",
    "vue": "^3.5.39",
    "vue-tippy": "^6.7.1",
    "vue-toastification": "^2.0.0-rc.5",
    "vuedraggable": "^4.1.0",
    "vuefire": "^3.2.3"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@types/cli-progress": "^3.11.6",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/language-plugin-pug": "^2.2.12",
    "@vue/test-utils": "^2.4.11",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "colors": "^1.4.0",
    "eslint": "^9.39.4",
    "firebase-admin": "^13.10.0",
    "firebase-tools": "^15.22.4",
    "jquery": "^3.7.1",
    "jsdom": "^24.1.3",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "pug": "^3.0.4",
    "sass": "^1.101.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7",
    "vue-good-table-next": "^0.2.2",
    "vue-tsc": "^3.3.6"
  },
  "peerDependencies": {
    "@sparticuz/chromium": "^149.0.0"
  },
  "peerDependenciesMeta": {
    "@sparticuz/chromium": {
      "optional": true
    }
  },
  "overrides": {
    "firebase": {
      "undici": "^6.21.3"
    }
  }
}
